---
// Base styles from the framework, then site theme + layout tweaks (see global.css).
import "terminal.css";
import "../styles/global.css";
import YandexMetrika from "../components/YandexMetrika.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  </head>
  <body class="terminal">
    <!-- Single place for page chrome: consistent top spacing for all routes. -->
    <main class="site-main">
      <slot />
    </main>
    <YandexMetrika />
  </body>
</html>
