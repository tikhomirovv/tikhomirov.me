---
// Base styles from the framework, then site theme + layout tweaks (see global.css).
import "terminal.css";
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import YandexMetrika from "../components/YandexMetrika.astro";
import type { Lang } from "../i18n/config";
import { defaultLang } from "../i18n/config";

interface Props {
  title: string;
  /** BCP 47 language tag for <html lang>. */
  lang?: Lang;
  description?: string;
}

const { title, lang = defaultLang, description } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  </head>
  <body class="terminal">
    <!-- Single place for page chrome: consistent top spacing for all routes. -->
    <main class="site-main">
      <slot />
    </main>
    <SiteFooter />
    <YandexMetrika />
  </body>
</html>
