---
/**
 * Global footer: one line of outbound links (no nav duplication, no top border).
 */
import { SITE_MAILTO, SITE_URL } from "../site/site-links";
---

<footer id="site-footer" class="site-footer" aria-label="Site">
  <div class="container">
    <p class="site-footer-links">
      <a href={SITE_MAILTO.primary}>email</a>
      {" · "}
      <a href={SITE_URL.telegram} target="_blank" rel="noopener noreferrer"
        >telegram</a
      >
      {" · "}
      <a href={SITE_URL.githubProfile} target="_blank" rel="noopener noreferrer"
        >github</a
      >
    </p>
  </div>
</footer>
