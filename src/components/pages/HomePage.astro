---
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../SiteNav.astro";
import { getEntry, render } from "astro:content";
import type { Lang } from "../../i18n/config";
interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const entryId = `${lang}/body` as const;
const entry = await getEntry("home", entryId);
if (!entry) {
  throw new Error(`Missing home content: ${entryId}.mdx`);
}

const { Content } = await render(entry);
const { title } = entry.data;
---

<Layout title={title} lang={lang}>
  <SiteNav lang={lang} />
  <div class="container md-content">
    <Content />

    {
      lang === "en" && (
        <>
          <section class="section-block">
            <h2>Best-fit work</h2>
            <div class="proof-list">
              <article class="proof-item">
                <h3>Backend-heavy product areas</h3>
                <p>
                  APIs, business logic, critical workflows, reliability, and
                  long-running systems.
                </p>
              </article>
              <article class="proof-item">
                <h3>SaaS and internal tools</h3>
                <p>
                  Products that need pragmatic engineering, careful ownership,
                  and steady delivery.
                </p>
              </article>
              <article class="proof-item">
                <h3>Migrations and optimization</h3>
                <p>
                  Security hardening, billing flows, PostgreSQL work,
                  performance fixes, and system cleanup.
                </p>
              </article>
            </div>
          </section>

          <section class="section-block">
            <h2>Selected proof</h2>
            <div class="proof-list">
              <article class="proof-item">
                <h3>MindLog</h3>
                <p>
                  Built and run with major solo ownership across backend,
                  infrastructure, billing, and product-critical systems.
                </p>
              </article>
              <article class="proof-item">
                <h3>Go mobile backend</h3>
                <p>
                  Reduced a slow dashboard flow from 20+ seconds to around 1
                  second and handled business-logic-heavy backend work.
                </p>
              </article>
              <article class="proof-item">
                <h3>Call-center CRM</h3>
                <p>
                  Reworked a fragile bonus-calculation subsystem around safer
                  recalculation, raw data preservation, and PostgreSQL-heavy
                  improvements.
                </p>
              </article>
            </div>
          </section>

          <section class="section-block">
            <h2>Explore the site</h2>
            <ul class="explore-list">
              <li>
                <a href="/selected-work">selected work</a>
                — Short case-study style summaries of the strongest backend and
                product work.
              </li>
              <li>
                <a href="/work-with-me">work with me</a>
                — Preferred collaboration format, best-fit projects, and how I
                usually work.
              </li>
              <li>
                <a href="/portfolio">resume</a>
                — A structured background summary with core experience, stack,
                and working style.
              </li>
            </ul>
          </section>
        </>
      )
    }

  </div>
</Layout>
