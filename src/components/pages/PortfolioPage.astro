---
/**
 * Renders portfolio markdown for the active locale.
 */
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../SiteNav.astro";
import { getEntry, render } from "astro:content";
import type { Lang } from "../../i18n/config";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const entryId = `${lang}/resume` as const;
const entry = await getEntry("portfolio", entryId);
if (!entry) {
  throw new Error(`Missing portfolio content: ${entryId}.mdx`);
}

const { Content } = await render(entry);
const { title } = entry.data;
const showLegacyBackLink = lang === "ru";
---

<Layout title={title} lang={lang}>
  <SiteNav lang={lang} />
  <div class="container md-content">
    <Content />
    {
      showLegacyBackLink && (
        <p class="back">
          <a href="/ru">← На главную</a>
        </p>
      )
    }
  </div>
</Layout>

<style>
  .md-content :global(hr) {
    border: none;
    border-top: 1px solid var(--progress-bar-background);
    margin: 2.5em 0;
  }

  .back {
    margin-top: 3em;
  }
</style>
